# Django Configuration Example
# Copy this file to .env and adjust the values for your local environment

DJANGO_SECRET_KEY=django-insecure-change-this-locally
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database Configuration
# If POSTGRES_ENGINE does not end with 'postgresql', it will default to SQLite
POSTGRES_ENGINE=django.db.backends.postgresql
POSTGRES_NAME=capacitacion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_local_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Email Configuration (Console for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com